{
  "expo": {
    "name": "ScientificState",
    "slug": "scientificstate",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "scientificstate",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.scientificstate.mobile"
    },
    "android": {
      "package": "org.scientificstate.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00FF88"
        }
      ],
      "expo-asset"
    ]
  }
}
