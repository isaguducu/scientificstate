{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientificstate.org/schemas/module-permission.schema.json",
  "title": "ModulePermission",
  "type": "object",
  "properties": {
    "network": { "type": "boolean", "default": false },
    "filesystem_read": { "type": "array", "items": { "type": "string" }, "default": [] },
    "filesystem_write": { "type": "array", "items": { "type": "string" }, "default": [] },
    "subprocess_spawn": { "type": "boolean", "default": false },
    "max_memory_mb": { "type": "integer", "minimum": 0 },
    "max_cpu_seconds": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
